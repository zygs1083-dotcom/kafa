{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Validation Record",
  "type": "object",
  "required": ["id", "surface", "findings", "result", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "surface": { "type": "string" },
    "acceptance_id": { "type": "string" },
    "commands": { "type": "string" },
    "command": { "type": "string" },
    "exit_code": { "type": ["integer", "null"] },
    "stdout_sha256": { "type": "string" },
    "artifact_path": { "type": "string" },
    "target_id": { "type": "string" },
    "executed_count": { "type": "integer" },
    "executed_count_source": { "type": "string", "enum": ["", "parsed", "manual", "policy"] },
    "allow_unlisted": { "type": "integer" },
    "no_network": { "type": "integer" },
    "policy_status": { "type": "string", "enum": ["", "allowed", "rejected", "manual"] },
    "policy_reason": { "type": "string" },
    "failure_mode_ids": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "string" },
    "result": { "type": "string", "enum": ["pass", "fail", "blocked", "partial"] },
    "residual_risk": { "type": "string" },
    "head_commit": { "type": "string" },
    "source_tree_hash": { "type": "string" },
    "tracked_diff_hash": { "type": "string" },
    "project_revision": { "type": "integer" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
