{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kafa:schema:31:validation",
  "title": "Kafa Validation Judgment",
  "type": "object",
  "required": [
    "id",
    "cycle_id",
    "candidate_sha",
    "surface",
    "result",
    "validation_status",
    "findings",
    "residual_risk",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "cycle_id": { "type": "string" },
    "candidate_sha": { "type": "string" },
    "acceptance_id": { "type": ["string", "null"] },
    "qualification_id": { "type": ["string", "null"] },
    "surface": { "type": "string" },
    "result": { "type": "string", "enum": ["pass", "fail", "blocked", "partial"] },
    "validation_status": { "type": "string", "enum": ["active", "superseded", "invalidated"] },
    "superseded_by": { "type": ["string", "null"] },
    "findings": { "type": "string" },
    "residual_risk": { "type": "string" },
    "created_at": { "type": "string" },
    "failure_mode_ids": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
