{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Task",
  "type": "object",
  "required": ["id", "task", "owner", "status", "acceptance_ids"],
  "properties": {
    "id": { "type": "string" },
    "task": { "type": "string" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["ready", "claimed", "in_progress", "blocked", "accepted", "failed", "cancelled", "skipped"]
    },
    "acceptance_ids": { "type": "array", "items": { "type": "string" } },
    "failure_mode_ids": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "tool_link": { "type": "string" },
    "evidence": { "type": "string" },
    "lease_agent": { "type": ["string", "null"] },
    "lease_token": { "type": ["string", "null"] },
    "retry_count": { "type": "integer" },
    "retry_budget": { "type": "integer" },
    "revision": { "type": "integer" }
  },
  "additionalProperties": true
}
