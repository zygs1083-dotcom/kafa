{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Task",
  "type": "object",
  "required": ["uid", "id", "cycle_id", "task", "owner", "status", "acceptance_ids"],
  "properties": {
    "uid": { "type": "string" },
    "id": { "type": "string" },
    "cycle_id": { "type": "string" },
    "task": { "type": "string" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "submitted", "accepted", "blocked", "cancelled"]
    },
    "acceptance_ids": { "type": "array", "items": { "type": "string" } },
    "failure_mode_ids": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "string" },
    "submitted_context_id": { "type": "string" },
    "accepted_by": { "type": "string" },
    "revision": { "type": "integer" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
