{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Task",
  "type": "object",
  "required": ["id", "task", "owner", "status", "acceptance_ids"],
  "properties": {
    "id": { "type": "string" },
    "task": { "type": "string" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "planned", "in_progress", "needs_input", "blocked", "testing", "review", "done", "accepted", "failed", "cancelled", "skipped", "partial"]
    },
    "acceptance_ids": { "type": "array", "items": { "type": "string" } },
    "failure_mode_ids": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "tool_link": { "type": "string" },
    "evidence": { "type": "string" }
  },
  "additionalProperties": true
}
