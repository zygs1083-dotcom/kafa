  "properties": {
    "id": { "type": "string" },
    "kind": { "type": "string" },
    "summary": { "type": "string" },
    "uri": { "type": "string" },
    "hash": { "type": "string" },
    "command": { "type": "string" },
    "exit_code": { "type": ["integer", "null"] },
