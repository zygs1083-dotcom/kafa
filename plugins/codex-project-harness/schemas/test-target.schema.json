{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kafa:schema:31:test-target",
  "title": "Codex Project Harness Test Target",
  "type": "object",
  "required": ["id", "kind", "command_template", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["unit", "integration", "lint", "build"] },
    "command_template": { "type": "string" },
    "description": { "type": "string" },
    "gateable": { "type": "integer" },
    "gate_block_reason": { "type": "string" },
    "stack_profile": { "type": "string", "enum": ["python", "node", "go", "rust", "java", "browser-e2e", "data-integration"] },
    "container_image": { "type": "string" },
    "requires_sandbox": { "type": "integer" },
    "requires_no_network": { "type": "integer" },
    "result_format": { "type": "string", "enum": ["regex", "junit", "pytest-json", "jest-json", "go-json", "cargo-nextest-json", "playwright-json"] },
    "result_path": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
