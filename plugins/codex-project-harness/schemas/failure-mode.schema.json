{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Failure Mode",
  "type": "object",
  "required": ["id", "feature", "scenario", "trigger", "expected_behavior", "risk", "status"],
  "properties": {
    "id": { "type": "string" },
    "feature": { "type": "string" },
    "scenario": { "type": "string" },
    "trigger": { "type": "string" },
    "expected_behavior": { "type": "string" },
    "recovery": { "type": "string" },
    "data_safety": { "type": "string" },
    "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "test_mapping": { "type": "string" },
    "status": { "type": "string", "enum": ["identified", "covered", "accepted", "exempt"] }
  },
  "additionalProperties": true
}
