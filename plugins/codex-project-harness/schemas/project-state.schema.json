{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Project State",
  "type": "object",
  "required": ["status", "phase", "current_cycle_id", "connector_project_key", "scope_status", "current_owner", "schema_version", "runtime_version", "project_id", "revision"],
  "properties": {
    "status": { "type": "string" },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "project_bootstrap",
        "requirement_baseline",
        "confirmation",
        "team_architecture",
        "planning",
        "implementation",
        "qa",
        "delivery_readiness",
        "retrospective",
        "archived"
      ]
    },
    "current_cycle_id": { "type": "string" },
    "connector_project_key": { "type": "string" },
    "scope_status": { "type": "string" },
    "current_owner": { "type": "string" },
    "schema_version": { "type": "integer" },
    "runtime_version": { "type": "string" },
    "project_id": { "type": "string" },
    "revision": { "type": "integer" },
    "blocked_reason": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
