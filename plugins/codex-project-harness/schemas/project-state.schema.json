{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Project State",
  "type": "object",
  "required": ["id", "status", "phase", "current_cycle_id", "scope_status", "current_owner", "schema_version", "runtime_version", "project_id", "revision", "updated_at"],
  "properties": {
    "id": { "type": "integer" },
    "status": { "type": "string" },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "project_bootstrap",
        "requirement_baseline",
        "confirmation",
        "team_architecture",
        "planning",
        "implementation",
        "qa",
        "delivery_readiness",
        "retrospective",
        "archived"
      ]
    },
    "current_cycle_id": { "type": "string" },
    "scope_status": { "type": "string" },
    "current_owner": { "type": "string" },
    "schema_version": { "type": "integer" },
    "runtime_version": { "type": "string" },
    "project_id": { "type": "string" },
    "revision": { "type": "integer" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
