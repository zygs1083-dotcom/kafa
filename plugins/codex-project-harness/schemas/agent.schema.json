{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Agent",
  "type": "object",
  "required": ["id", "role", "status", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "role": { "type": "string" },
    "template_path": { "type": "string" },
    "status": { "type": "string", "enum": ["available", "leased", "disabled"] },
    "tool_permissions": { "type": "string" },
    "session_id": { "type": "string" },
    "lease_task_id": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
