{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "run_id", "task_id", "agent_id", "fence", "branch_name", "target_id", "status"],
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "fence": { "type": "integer" },
    "base_commit_sha": { "type": "string" },
    "head_commit_sha": { "type": "string" },
    "tree_sha": { "type": "string" },
    "branch_name": { "type": "string" },
    "target_id": { "type": "string" },
    "status": { "type": "string", "enum": ["reported", "verified", "verification_failed"] },
    "report_id": { "type": "string" },
    "evidence_id": { "type": "string" },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" }
  }
}
