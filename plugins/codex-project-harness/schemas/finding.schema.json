{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kafa:schema:31:finding",
  "title": "Codex Project Harness Finding",
  "type": "object",
  "required": ["id", "surface", "severity", "status", "summary", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "cycle_id": { "type": "string" },
    "candidate_sha": { "type": "string" },
    "surface": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "status": { "type": "string", "enum": ["open", "resolved", "accepted", "false-positive"] },
    "summary": { "type": "string" },
    "waived_by": { "type": "string" },
    "waiver_reason": { "type": "string" },
    "waiver_scope": { "type": "string" },
    "waived_revision": { "type": ["integer", "null"] },
    "waiver_expires_at": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
