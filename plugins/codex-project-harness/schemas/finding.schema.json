{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Finding",
  "type": "object",
  "required": ["id", "surface", "severity", "status", "summary", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "surface": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "status": { "type": "string", "enum": ["open", "resolved", "accepted", "false-positive"] },
    "summary": { "type": "string" },
    "evidence_id": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
