{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "tool", "mode", "artifact", "action", "payload_json", "payload_hash", "status", "idempotency_key", "attempt_count", "next_retry_at", "connector_status", "blocked_reason", "execution_fence", "claimed_at", "claim_expires_at", "last_recovery_at", "remote_recovery_count", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "tool": { "type": "string" },
    "mode": { "type": "string", "enum": ["read-only", "draft-write", "write-confirm", "write-auto", "disabled"] },
    "artifact": { "type": "string" },
    "action": { "type": "string" },
    "payload_json": { "type": "string" },
    "payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "type": "string", "enum": ["planned", "draft", "confirmed", "executing", "completed", "retryable_failed", "unknown", "blocked"] },
    "confirmation": { "type": "string" },
    "external_id": { "type": "string" },
    "external_link": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "attempt_count": { "type": "integer" },
    "next_retry_at": { "type": "string" },
    "connector_status": { "type": "string", "enum": ["available", "degraded", "blocked"] },
    "blocked_reason": { "type": "string" },
    "execution_fence": { "type": "integer" },
    "claimed_at": { "type": "string" },
    "claim_expires_at": { "type": "string" },
    "last_recovery_at": { "type": "string" },
    "remote_recovery_count": { "type": "integer" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
