{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Agent Session",
  "type": "object",
  "required": ["session_id", "agent_id", "role", "context_id", "origin", "trust_level", "status"],
  "properties": {
    "session_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "role": { "type": "string", "enum": ["developer", "qa-reviewer", "reviewer", "architect", "product", "security"] },
    "context_id": { "type": "string" },
    "provider_session_id": { "type": "string" },
    "origin": { "type": "string", "enum": ["manual", "connector"] },
    "trust_level": { "type": "string", "enum": ["local-only", "human-confirmed", "connector"] },
    "status": { "type": "string" },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" }
  },
  "additionalProperties": true
}
