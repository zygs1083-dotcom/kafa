{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kafa:schema:31:requirement",
  "title": "Codex Project Harness Requirement",
  "type": "object",
  "required": ["uid", "id", "cycle_id", "kind", "body", "status", "revision", "updated_at"],
  "properties": {
    "uid": { "type": "string" },
    "id": { "type": "string" },
    "cycle_id": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["goal", "functional", "non-functional", "non-goal", "assumption", "open-question", "architecture"]
    },
    "body": { "type": "string" },
    "priority": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "cancelled"] },
    "revision": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
