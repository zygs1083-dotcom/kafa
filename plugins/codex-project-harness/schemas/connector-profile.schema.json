{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Connector Profile",
  "type": "object",
  "required": ["id", "tool", "project_key", "status", "scope_json", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "tool": { "type": "string", "enum": ["github", "linear", "notion", "figma", "slack"] },
    "project_key": { "type": "string" },
    "status": { "type": "string", "enum": ["bound", "disabled"] },
    "scope_json": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
