{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kafa:schema:31:delivery",
  "title": "Codex Project Harness Delivery Record",
  "type": "object",
  "required": ["id", "scope", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "cycle_id": { "type": "string" },
    "candidate_sha": { "type": "string" },
    "scope": { "type": "string" },
    "acceptance": { "type": "string" },
    "changed_files": { "type": "string" },
    "validation": { "type": "string" },
    "qa": { "type": "string" },
    "failure_mode_coverage": { "type": "string" },
    "quality_gate": { "type": "string" },
    "data_config_notes": { "type": "string" },
    "known_gaps": { "type": "string" },
    "handoff": { "type": "string" },
    "decision_status": {
      "type": "string",
      "enum": [
        "delivered",
        "accepted-risk",
        "same-context-degraded",
        "historical-migrated"
      ]
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
