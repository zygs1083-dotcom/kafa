{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Adapter Mapping",
  "type": "object",
  "required": ["id", "tool", "mode", "artifact", "idempotency_key", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "tool": { "type": "string" },
    "mode": { "type": "string", "enum": ["disabled", "read-only", "draft-write", "write-confirm", "write-auto"] },
    "artifact": { "type": "string" },
    "external_id": { "type": "string" },
    "external_link": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "evidence": { "type": "string" },
    "fallback": { "type": "string" },
    "confirmation_needed": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
