{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness External Session Verification",
  "type": "object",
  "required": ["id", "session_id", "verifier", "conclusion", "commit_sha", "origin", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "session_id": { "type": "string" },
    "verifier": { "type": "string" },
    "conclusion": { "type": "string", "enum": ["verified", "failed"] },
    "commit_sha": { "type": "string" },
    "origin": { "type": "string", "enum": ["manual", "connector"] },
    "verification_token": { "type": "string" },
    "external_link": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
