{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Connector Budget",
  "type": "object",
  "required": ["id", "tool", "operation", "scope_key", "status", "retry_after_at", "last_error", "free_plan_risk", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "tool": { "type": "string" },
    "operation": { "type": "string" },
    "scope_key": { "type": "string" },
    "status": { "type": "string", "enum": ["available", "degraded", "blocked"] },
    "retry_after_at": { "type": "string" },
    "rate_limit_remaining": { "type": ["integer", "null"] },
    "rate_limit_reset_at": { "type": "string" },
    "last_status_code": { "type": ["integer", "null"] },
    "last_error": { "type": "string" },
    "free_plan_risk": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
