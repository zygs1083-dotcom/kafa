{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kafa Local Quality Gate",
  "type": "object",
  "required": [
    "id",
    "sequence",
    "cycle_id",
    "candidate_sha",
    "gate_status",
    "gate",
    "producer_context_id",
    "reviewer_context_id",
    "review_status",
    "result",
    "blocking_findings",
    "residual_risk",
    "reviewed_revision",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "sequence": { "type": "integer" },
    "cycle_id": { "type": "string" },
    "candidate_sha": { "type": "string" },
    "gate_status": { "type": "string", "enum": ["active", "superseded", "legacy-ambiguous"] },
    "superseded_by": { "type": ["string", "null"] },
    "gate": { "type": "string" },
    "producer_context_id": { "type": "string" },
    "reviewer_context_id": { "type": "string" },
    "review_status": {
      "type": "string",
      "enum": ["reviewed-local", "same-context-degraded"]
    },
    "result": { "type": "string", "enum": ["pass", "fail", "conditional", "blocked"] },
    "blocking_findings": { "type": "string" },
    "residual_risk": { "type": "string" },
    "reviewed_revision": { "type": "integer" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
