{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Project Harness Quality Gate",
  "type": "object",
  "required": ["gate", "reviewed_commit", "reviewer_context", "result"],
  "properties": {
    "gate": { "type": "string" },
    "reviewed_commit": { "type": "string" },
    "evidence_commit": { "type": "string" },
    "diff_hash": { "type": "string" },
    "base_commit": { "type": "string" },
    "head_commit": { "type": "string" },
    "tracked_diff_hash": { "type": "string" },
    "project_revision": { "type": "integer" },
    "reviewer_context": {
      "type": "string",
      "enum": ["fresh", "same-context-degraded", "external"]
    },
    "result": {
      "type": "string",
      "enum": ["pass", "fail", "conditional", "blocked"]
    },
    "blocking_findings": { "type": "string" },
    "commands": { "type": "string" },
    "evidence": { "type": "string" },
    "residual_risk": { "type": "string" },
    "reviewer_session_id": { "type": "string" },
    "reviewer_attestation_id": { "type": "string" },
    "review_trust_level": { "type": "string", "enum": ["local-only", "human-confirmed", "connector"] }
  },
  "additionalProperties": true
}
